if __name__ == "__main__":
    # Simulated Market Data (100 days)
    np.random.seed(42)
    dates = pd.date_range(start="2026-01-01", periods=100)
    
    # Simulating two highly correlated financial assets
    asset_a = pd.Series(np.cumsum(np.random.normal(0, 1, 100)) + 100, index=dates)
    asset_b = asset_a * 1.5 + np.random.normal(0, 0.5, 100)
    
    # Simulating an NLP sentiment score array (-1.0 to 1.0) extracted from financial news
    mock_sentiment = np.random.uniform(-1, 1, 100)
    
    # Initialize MQFS Engine
    engine = SemanticStatArb(asset_x=asset_a, asset_y=asset_b, lookback_window=20)
    
    # Run Cointegration
    hedge, p_val = engine.calculate_cointegration()
    print(f"[MQFS Research] Hedge Ratio: {hedge:.4f} | Spread p-value: {p_val:.4f}")
    
    # Generate Signals
    trade_signals = engine.generate_sentiment_adjusted_signals(sentiment_vector=mock_sentiment)
    print("\n[MQFS Research] Recent Output Signals:")
    print(trade_signals.tail())
